{% load static %}
<!DOCTYPE html>
<html lang="pt-BR" dir="ltr">

  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Novo Evento | Roselar</title>

    <link rel="apple-touch-icon" sizes="180x180" href="{% static 'assets/img/favicons/apple-touch-icon.png' %}">
    <link rel="icon" type="image/png" sizes="32x32" href="{% static 'assets/img/favicons/favicon-32x32.png' %}">
    <link rel="shortcut icon" type="image/x-icon" href="{% static 'assets/img/favicons/favicon.ico' %}">
    <meta name="theme-color" content="#ffffff">

    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700&amp;display=swap" rel="stylesheet">
    <link href="{% static 'assets/css/theme.css' %}" rel="stylesheet" />
    <link href="{% static 'assets/css/user.css' %}" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>
      .form-control, .form-select, .btn { border-radius: 0 !important; }
      #dropdownUserButton { border-radius: 0.375rem !important; }
    </style>
  </head>

  <body>
    <main class="main" id="top">
      <nav class="navbar navbar-expand-lg fixed-top navbar-dark" data-navbar-on-scroll="data-navbar-on-scroll">
        <div class="container"><a class="navbar-brand" href="{% url 'core:index' %}"><img src="{% static 'assets/img/Logo.png' %}?v=2" alt="" style="height: 40px;" /></a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"><i class="fa-solid fa-bars text-white fs-3"></i></button>
          <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav ms-auto">
              <li class="nav-item"><a class="nav-link" href="{% url 'core:index' %}">Início</a></li>
              <li class="nav-item"><a class="nav-link" href="{% url 'sales:quotes_hub' %}">Orçamentos</a></li>
              <li class="nav-item"><a class="nav-link active" href="{% url 'calendar_app:calendar' %}">Calendário</a></li>
              <li class="nav-item">
                <button id="dropdownUserButton" data-dropdown-toggle="dropdownUser" class="btn btn-light text-black d-flex align-items-center" type="button">
                  <span class="me-2">{{ user.username }}</span>
                  <svg style="width:14px;height:14px;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/></svg>
                </button>
                <div id="dropdownUser" class="z-10 hidden bg-white divide-y divide-gray-100 rounded-lg shadow w-72">
                  <div class="px-4 py-3 text-sm text-gray-900"><div class="font-medium">{{ user.username }}</div><div class="truncate">{{ user.email }}</div></div>
                  <ul class="py-2 text-sm text-gray-700"><li><a href="{% url 'core:dashboard' %}" class="block px-4 py-2 hover:bg-gray-100"><i class="fa-solid fa-user me-2"></i>Minha Conta</a></li></ul>
                  <div class="py-2"><a href="{% url 'accounts:logout' %}" class="block px-4 py-2 text-sm text-red-700 hover:bg-gray-100"><i class="fa-solid fa-right-from-bracket me-2"></i>Sair</a></div>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </nav>

      <section class="py-8" style="min-height: 100vh;">
        <div class="bg-dark" style="position: absolute; top: 0; left: 0; right: 0; height: 30vh; z-index: -1;"></div>

        <div class="container">
          <div class="row justify-content-center">
            <div class="col-lg-8">
              <div class="bg-white p-5 shadow-lg" style="border-radius: 0;">

                <h1 class="fw-bold mb-4 text-center">
                  <i class="fa-solid fa-plus-circle me-2"></i>Novo Evento
                </h1>

                {% if error %}
                <div class="alert alert-danger">{{ error }}</div>
                {% endif %}

                <form method="post">
                  {% csrf_token %}

                  <div class="mb-3">
                    <label for="title" class="form-label fw-bold">Título <span class="text-danger">*</span></label>
                    <input type="text" id="title" name="title" class="form-control" required
                           placeholder="Ex: Reunião com cliente, Entrega do pedido..."
                           value="{{ request.POST.title }}">
                  </div>

                  <div class="mb-3">
                    <label for="description" class="form-label fw-bold">Descrição</label>
                    <textarea id="description" name="description" class="form-control" rows="3"
                              placeholder="Descrição opcional do evento...">{{ request.POST.description }}</textarea>
                  </div>

                  <div class="row">
                    <div class="col-md-6 mb-3">
                      <label for="event_date" class="form-label fw-bold">Data <span class="text-danger">*</span></label>
                      <input type="date" id="event_date" name="event_date" class="form-control" required
                             value="{{ request.POST.event_date }}">
                    </div>
                    <div class="col-md-6 mb-3">
                      <label for="event_type" class="form-label fw-bold">Tipo</label>
                      <select id="event_type" name="event_type" class="form-select">
                        {% for val, label in event_types %}
                        <option value="{{ val }}" {% if request.POST.event_type == val %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                      </select>
                    </div>
                  </div>

                  <!-- Lembretes personalizáveis -->
                  <div class="mb-3">
                    <label class="form-label fw-bold"><i class="fa-solid fa-bell me-1"></i>Lembretes</label>
                    <p class="text-muted small mb-2">Escolha quando deseja ser lembrado deste evento:</p>
                    <div class="row g-2">
                      <div class="col-6 col-md-4">
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" name="reminders" value="7" id="rem7"
                                 {% if "7" in selected_reminders %}checked{% endif %}>
                          <label class="form-check-label" for="rem7">7 dias antes</label>
                        </div>
                      </div>
                      <div class="col-6 col-md-4">
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" name="reminders" value="3" id="rem3"
                                 {% if not selected_reminders or "3" in selected_reminders %}checked{% endif %}>
                          <label class="form-check-label" for="rem3">3 dias antes</label>
                        </div>
                      </div>
                      <div class="col-6 col-md-4">
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" name="reminders" value="1" id="rem1"
                                 {% if not selected_reminders or "1" in selected_reminders %}checked{% endif %}>
                          <label class="form-check-label" for="rem1">1 dia antes</label>
                        </div>
                      </div>
                      <div class="col-6 col-md-4">
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" name="reminders" value="0" id="rem0"
                                 {% if not selected_reminders or "0" in selected_reminders %}checked{% endif %}>
                          <label class="form-check-label" for="rem0">No dia</label>
                        </div>
                      </div>
                      <div class="col-6 col-md-4">
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" name="reminders" value="14" id="rem14"
                                 {% if "14" in selected_reminders %}checked{% endif %}>
                          <label class="form-check-label" for="rem14">14 dias antes</label>
                        </div>
                      </div>
                      <div class="col-6 col-md-4">
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" name="reminders" value="30" id="rem30"
                                 {% if "30" in selected_reminders %}checked{% endif %}>
                          <label class="form-check-label" for="rem30">30 dias antes</label>
                        </div>
                      </div>
                    </div>
                    <!-- Lembrete Personalizado -->
                    <div class="mt-3 d-flex align-items-center gap-2">
                      <input class="form-check-input mt-0" type="checkbox" name="reminder_custom_check" id="remCustom"
                             {% if request.POST.reminder_custom_days %}checked{% endif %}>
                      <label class="form-check-label me-1" for="remCustom">Personalizado:</label>
                      <input type="number" name="reminder_custom_days" class="form-control form-control-sm" style="width: 80px;"
                             min="1" max="365" placeholder="dias"
                             value="{{ request.POST.reminder_custom_days }}"
                             {% if not request.POST.reminder_custom_days %}disabled{% endif %}>
                      <span class="text-muted small">dias antes</span>
                    </div>
                  </div>

                  <div class="text-center mt-4 d-flex gap-3 justify-content-center">
                    <a href="{% url 'calendar_app:calendar' %}" class="btn btn-outline-secondary btn-lg">
                      <i class="fa-solid fa-arrow-left me-1"></i>Cancelar
                    </a>
                    <button type="submit" class="btn btn-dark btn-lg">
                      <i class="fa-solid fa-check me-1"></i>Criar Evento
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-0 bg-dark">
        <div class="container">
          <div class="row justify-content-md-between justify-content-evenly py-4">
            <div class="col-12 col-sm-8 col-md-6 col-lg-auto text-center text-md-start">
              <p class="fs--1 my-2 fw-light text-200">Todos os direitos reservados &copy; Roselar 2026</p>
            </div>
            <div class="col-12 col-sm-8 col-md-6">
              <p class="fs--1 my-2 text-center text-md-end text-200">Feito com &hearts; pela Roselar</p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/is_js@0.9.0/is.min.js"></script>
    <script src="{% static 'assets/js/theme.js' %}"></script>
    <script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>
    <link rel="stylesheet" href="https://unicons.iconscout.com/release/v4.0.0/css/line.css">
    <script>
      // Toggle custom reminder days input
      const remCustom = document.getElementById('remCustom');
      const daysInput = document.querySelector('input[name="reminder_custom_days"]');
      remCustom.addEventListener('change', function() {
        daysInput.disabled = !this.checked;
        if (this.checked) daysInput.focus();
        else daysInput.value = '';
      });
    </script>
  </body>
</html>
