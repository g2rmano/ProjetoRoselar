{% load static %}
<!DOCTYPE html>
<html lang="pt-BR" dir="ltr">

  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ event.title }} | Roselar</title>

    <link rel="apple-touch-icon" sizes="180x180" href="{% static 'assets/img/favicons/apple-touch-icon.png' %}">
    <link rel="icon" type="image/png" sizes="32x32" href="{% static 'assets/img/favicons/favicon-32x32.png' %}">
    <link rel="shortcut icon" type="image/x-icon" href="{% static 'assets/img/favicons/favicon.ico' %}">
    <meta name="theme-color" content="#ffffff">

    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700&amp;display=swap" rel="stylesheet">
    <link href="{% static 'assets/css/theme.css' %}" rel="stylesheet" />
    <link href="{% static 'assets/css/user.css' %}" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <style>
      .detail-table th { width: 180px; background: #f8f9fa; font-weight: 600; }
      .status-PENDING { background-color: #ffc107; color: #333; }
      .status-DONE { background-color: #198754; color: white; }
      .status-OVERDUE { background-color: #dc3545; color: white; }
      .status-CANCELED { background-color: #6c757d; color: white; }
      .status-badge { padding: 0.35rem 0.75rem; font-weight: 600; font-size: 0.85rem; display: inline-block; border-radius: 3px; }
      .reminder-row { border-left: 3px solid #fd7e14; }
      .reminder-row.read { border-left-color: #adb5bd; opacity: 0.7; }
      #dropdownUserButton { border-radius: 0.375rem !important; }
    </style>
  </head>

  <body>
    <main class="main" id="top">
      <nav class="navbar navbar-expand-lg fixed-top navbar-dark" data-navbar-on-scroll="data-navbar-on-scroll">
        <div class="container"><a class="navbar-brand" href="{% url 'core:index' %}"><img src="{% static 'assets/img/Logo.png' %}?v=2" alt="" style="height: 40px;" /></a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"><i class="fa-solid fa-bars text-white fs-3"></i></button>
          <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav ms-auto">
              <li class="nav-item"><a class="nav-link" href="{% url 'core:index' %}">Início</a></li>
              <li class="nav-item"><a class="nav-link" href="{% url 'sales:quotes_hub' %}">Orçamentos</a></li>
              <li class="nav-item"><a class="nav-link active" href="{% url 'calendar_app:calendar' %}">Calendário</a></li>
              <li class="nav-item">
                <button id="dropdownUserButton" data-dropdown-toggle="dropdownUser" class="btn btn-light text-black d-flex align-items-center" type="button">
                  <span class="me-2">{{ user.username }}</span>
                  <svg style="width:14px;height:14px;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/></svg>
                </button>
                <div id="dropdownUser" class="z-10 hidden bg-white divide-y divide-gray-100 rounded-lg shadow w-72">
                  <div class="px-4 py-3 text-sm text-gray-900"><div class="font-medium">{{ user.username }}</div><div class="truncate">{{ user.email }}</div></div>
                  <ul class="py-2 text-sm text-gray-700"><li><a href="{% url 'core:dashboard' %}" class="block px-4 py-2 hover:bg-gray-100"><i class="fa-solid fa-user me-2"></i>Minha Conta</a></li></ul>
                  <div class="py-2"><a href="{% url 'accounts:logout' %}" class="block px-4 py-2 text-sm text-red-700 hover:bg-gray-100"><i class="fa-solid fa-right-from-bracket me-2"></i>Sair</a></div>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </nav>

      <section class="py-8" style="min-height: 100vh;">
        <div class="bg-dark" style="position: absolute; top: 0; left: 0; right: 0; height: 30vh; z-index: -1;"></div>

        <div class="container">
          <div class="row justify-content-center">
            <div class="col-lg-10">
              <div class="bg-white p-4 shadow-lg" style="border-radius: 0;">

                <div class="d-flex justify-content-between align-items-center mb-4">
                  <h1 class="fw-bold mb-0"><i class="fa-solid fa-calendar-day me-2"></i>Detalhe do Evento</h1>
                  <a href="{% url 'calendar_app:calendar' %}" class="btn btn-outline-dark" style="border-radius:0;">
                    <i class="fa-solid fa-calendar me-1"></i>Voltar ao Calendário
                  </a>
                </div>

                <!-- Informações do Evento -->
                <div class="table-responsive mb-4">
                  <table class="table table-bordered detail-table mb-0">
                    <tbody>
                      <tr>
                        <th>Título</th>
                        <td class="fw-bold fs-5">{{ event.title }}</td>
                      </tr>
                      <tr>
                        <th>Tipo</th>
                        <td>{{ event.get_event_type_display }}</td>
                      </tr>
                      <tr>
                        <th>Status</th>
                        <td>
                          <span class="status-badge status-{% if event.is_overdue %}OVERDUE{% else %}{{ event.status }}{% endif %}">
                            {% if event.is_overdue %}Atrasado{% else %}{{ event.get_status_display }}{% endif %}
                          </span>
                        </td>
                      </tr>
                      <tr>
                        <th>Data</th>
                        <td>
                          {{ event.event_date|date:"d/m/Y" }}
                          {% if event.event_time %} às {{ event.event_time|time:"H:i" }}{% endif %}
                          {% if event.days_until > 0 %}
                            <small class="text-muted">(em {{ event.days_until }} dia{{ event.days_until|pluralize:"s" }})</small>
                          {% elif event.days_until == 0 %}
                            <span class="badge bg-primary ms-1">HOJE</span>
                          {% else %}
                            <span class="badge bg-danger ms-1">{{ event.days_until|cut:"-" }} dia{{ event.days_until|cut:"-"|pluralize:"s" }} atrasado</span>
                          {% endif %}
                        </td>
                      </tr>
                      <tr>
                        <th>Vendedor</th>
                        <td>{{ event.assigned_to.get_full_name|default:event.assigned_to.username }}</td>
                      </tr>
                      {% if event.customer %}
                      <tr>
                        <th>Cliente</th>
                        <td>{{ event.customer.name }}</td>
                      </tr>
                      {% endif %}
                      {% if event.quote %}
                      <tr>
                        <th>Orçamento</th>
                        <td>
                          <a href="{% url 'sales:quote_detail' event.quote_id %}">{{ event.quote.number }}</a>
                        </td>
                      </tr>
                      {% endif %}
                      {% if event.description %}
                      <tr>
                        <th>Descrição</th>
                        <td>{{ event.description }}</td>
                      </tr>
                      {% endif %}
                      <tr>
                        <th>Criado em</th>
                        <td>{{ event.created_at|date:"d/m/Y H:i" }}</td>
                      </tr>
                    </tbody>
                  </table>
                </div>

                <!-- Ações -->
                {% if event.status == "PENDING" %}
                <div class="d-flex gap-2 mb-4">
                  <form method="post" action="{% url 'calendar_app:event_mark_done' event.pk %}">
                    {% csrf_token %}
                    <button type="submit" class="btn btn-success" style="border-radius:0;">
                      <i class="fa-solid fa-check me-1"></i>Marcar como Concluído
                    </button>
                  </form>
                  <form method="post" action="{% url 'calendar_app:event_mark_canceled' event.pk %}">
                    {% csrf_token %}
                    <button type="submit" class="btn btn-outline-danger" style="border-radius:0;"
                            onclick="return confirm('Tem certeza que deseja cancelar este evento?');">
                      <i class="fa-solid fa-xmark me-1"></i>Cancelar Evento
                    </button>
                  </form>
                </div>
                {% endif %}

                <!-- Lembretes -->
                {% if reminders %}
                <h4 class="fw-bold mb-3"><i class="fa-solid fa-bell me-1"></i>Lembretes</h4>
                <div class="table-responsive">
                  <table class="table table-hover">
                    <thead class="table-light">
                      <tr>
                        <th>Data</th>
                        <th>Mensagem</th>
                        <th>Status</th>
                        <th>Lido</th>
                      </tr>
                    </thead>
                    <tbody>
                      {% for r in reminders %}
                      <tr class="reminder-row {% if r.read %}read{% endif %}">
                        <td>{{ r.remind_date|date:"d/m/Y" }}</td>
                        <td>{{ r.message|default:"-" }}</td>
                        <td>{{ r.get_status_display }}</td>
                        <td>
                          {% if r.read %}
                            <i class="fa-solid fa-check-circle text-success"></i> {{ r.read_at|date:"d/m H:i" }}
                          {% else %}
                            <i class="fa-regular fa-circle text-muted"></i>
                          {% endif %}
                        </td>
                      </tr>
                      {% endfor %}
                    </tbody>
                  </table>
                </div>
                {% endif %}

                <div class="text-center mt-4">
                  <a href="{% url 'calendar_app:calendar' %}?year={{ event.event_date.year }}&month={{ event.event_date.month }}" class="btn btn-outline-secondary" style="border-radius:0;">
                    <i class="fa-solid fa-arrow-left me-2"></i>Voltar ao Calendário
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="py-0 bg-dark">
        <div class="container">
          <div class="row justify-content-md-between justify-content-evenly py-4">
            <div class="col-12 col-sm-8 col-md-6 col-lg-auto text-center text-md-start">
              <p class="fs--1 my-2 fw-light text-200">Todos os direitos reservados &copy; Roselar 2026</p>
            </div>
            <div class="col-12 col-sm-8 col-md-6">
              <p class="fs--1 my-2 text-center text-md-end text-200">Feito com &hearts; pela Roselar</p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/is_js@0.9.0/is.min.js"></script>
    <script src="{% static 'assets/js/theme.js' %}"></script>
    <script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>
    <link rel="stylesheet" href="https://unicons.iconscout.com/release/v4.0.0/css/line.css">
  </body>
</html>
