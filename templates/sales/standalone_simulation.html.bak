{% load static %}
<!DOCTYPE html>
<html lang="pt-BR" dir="ltr">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Simulação Rápida | Roselar</title>
  <link rel="apple-touch-icon" sizes="180x180" href="{% static 'assets/img/favicons/apple-touch-icon.png' %}">
  <link rel="icon" type="image/png" sizes="32x32" href="{% static 'assets/img/favicons/favicon-32x32.png' %}">
  <link rel="icon" type="image/png" sizes="16x16" href="{% static 'assets/img/favicons/favicon-16x16.png' %}">
  <link rel="shortcut icon" type="image/x-icon" href="{% static 'assets/img/favicons/favicon.ico' %}">
  <meta name="theme-color" content="#ffffff">

  <link rel="preconnect" href="https://fonts.gstatic.com">
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="{% static 'assets/css/theme.css' %}" rel="stylesheet">
  <link href="{% static 'assets/css/user.css' %}" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <style>
    :root {
      --brand:  #0A2640;
      --green:  #198754;
      --orange: #fd7e14;
      --red:    #dc3545;
      --gray:   #6c757d;
      --yellow: #ffc107;
    }
    body { font-family: 'Manrope', sans-serif; }

    .sim-card { border: 1px solid #dee2e6; background: #fff; padding: 1.1rem; margin-bottom: .9rem; }
    .sim-card .lbl { font-size: .76rem; text-transform: uppercase; letter-spacing: .05em; color: var(--gray); font-weight: 600; margin-bottom: .15rem; }
    .sim-card .val { font-size: 1.3rem; font-weight: 700; color: var(--brand); }
    .sim-card .val.green  { color: var(--green); }
    .sim-card .val.red    { color: var(--red); }
    .sim-card .val.orange { color: var(--orange); }

    .hi-card { color: #fff; padding: 1.5rem; margin-bottom: .9rem; }
    .hi-card .lbl { font-size: .76rem; text-transform: uppercase; letter-spacing: .05em; opacity: .8; margin-bottom: .2rem; }
    .hi-card .val { font-size: 1.8rem; font-weight: 700; }
    .hi-card.brand  { background: var(--brand); }
    .hi-card.green  { background: var(--green); }
    .hi-card.orange { background: var(--orange); }
    .hi-card.red    { background: var(--red); }
    .hi-card.gray   { background: var(--gray); }

    .sec-hdr { background: var(--brand); color: #fff; padding: .6rem 1rem; font-weight: 600; font-size: .88rem; display: flex; align-items: center; gap: .5rem; margin-bottom: 0; }
    .sec-body { border: 1px solid #dee2e6; border-top: none; padding: 1.1rem; background: #fff; margin-bottom: 1.4rem; }

    .slider-wrap { position: relative; padding: .5rem 0 1.5rem; }
    .slider-wrap input[type=range] {
      -webkit-appearance: none; appearance: none;
      width: 100%; height: 8px; outline: none; border-radius: 4px; cursor: pointer;
      background: linear-gradient(to right, var(--red) 0%, var(--brand) 100%);
    }
    .slider-wrap input[type=range]::-webkit-slider-thumb {
      -webkit-appearance: none; width: 26px; height: 26px;
      border-radius: 50%;
      background: #fff; border: 3px solid var(--brand);
      box-shadow: 0 2px 6px rgba(0,0,0,.25); cursor: pointer;
    }
    .slider-wrap input[type=range]::-moz-range-thumb {
      width: 24px; height: 24px; border-radius: 50%;
      background: #fff; border: 3px solid var(--brand);
      box-shadow: 0 2px 6px rgba(0,0,0,.25); cursor: pointer;
    }



    .margin-warning { background: #fff3cd; border: 1px solid var(--yellow); padding: .85rem; margin-bottom: 1rem; font-size: .87rem; border-radius: 4px; }
    .margin-ok { background: #e8f5e9; border: 1px solid var(--green); padding: .85rem; margin-bottom: 1rem; font-size: .87rem; border-radius: 4px; }
    .margin-danger { background: #f8d7da; border: 1px solid #f1aeb5; padding: .85rem; margin-bottom: 1rem; font-size: .87rem; border-radius: 4px; color: #842029; }

    .commission-toggle {
      width: 100%; border: 0; background: transparent; color: #fff;
      padding: 0; text-align: left;
      display: flex; align-items: center; justify-content: space-between; gap: .6rem;
    }
    .commission-toggle .toggle-arrow { transition: transform .2s ease; opacity: .9; }
    .commission-toggle[aria-expanded="true"] .toggle-arrow { transform: rotate(180deg); }

    .btn-brand  { background: var(--brand); color: #fff; border: none; padding: .55rem 1.4rem; font-weight: 600; cursor: pointer; }
    .btn-brand:hover { background: #08203a; color: #fff; }
    .btn-green  { background: var(--green); color: #fff; border: none; padding: .55rem 1.4rem; font-weight: 600; cursor: pointer; }
    .btn-green:hover { background: #146c43; color: #fff; }
    .btn-outline { background: transparent; border: 1px solid var(--gray); color: var(--gray); padding: .55rem 1.4rem; font-weight: 600; cursor: pointer; }
    .btn-outline:hover { background: #f8f9fa; }

    /* value input */
    .value-input { font-size: 1.4rem; font-weight: 700; color: var(--brand); border: 2px solid var(--brand); padding: .6rem 1rem; text-align: right; }
    .value-input:focus { border-color: var(--green); box-shadow: 0 0 0 .15rem rgba(25,135,84,.25); outline: none; }

    @keyframes flashUpdate { 0%{opacity:.4} 100%{opacity:1} }
    .flash { animation: flashUpdate .3s ease; }
  </style>
</head>

<body>
  <main class="main" id="top">
    <nav class="navbar navbar-expand-lg fixed-top navbar-dark" data-navbar-on-scroll="data-navbar-on-scroll">
      <div class="container">
        <a class="navbar-brand" href="{% url 'core:index' %}">
          <img src="{% static 'assets/img/Logo.png' %}?v=2" alt="" style="height: 40px;">
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent">
          <i class="fa-solid fa-bars text-white fs-3"></i>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item"><a class="nav-link" href="{% url 'core:index' %}">Início</a></li>
            <li class="nav-item"><a class="nav-link" href="{% url 'sales:quotes_hub' %}">Orçamentos</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <section class="py-5" style="min-height: 100vh;">
      <div style="position: absolute; top: 0; left: 0; right: 0; height: 28vh; background: var(--brand); z-index: -1;"></div>

      <div class="container" style="margin-top: 80px;">
        <div class="row justify-content-center">
          <div class="col-12 col-xl-11">

            <!-- Title bar -->
            <div class="bg-white p-4 shadow-sm mb-4">
              <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                  <h4 class="fw-bold mb-1" style="color: var(--brand);">
                    <i class="fa-solid fa-calculator me-2"></i>Simulação Rápida
                  </h4>
                  <span style="color: var(--gray);">
                    Simule valores de venda sem precisar criar um orçamento
                  </span>
                </div>
                <a href="{% url 'core:index' %}" class="btn-outline" style="text-decoration: none;">
                  <i class="fa-solid fa-arrow-left me-1"></i>Voltar
                </a>
              </div>
            </div>

            <form method="post" id="sim-form">
              {% csrf_token %}
              <input type="hidden" name="discount_percent"       id="h-discount">
              <input type="hidden" name="price_increase_percent" id="h-price-inc">
              <input type="hidden" name="sim_installments"       id="h-installments">
              <input type="hidden" name="sim_payment_type"       id="h-ptype">
              <input type="hidden" name="sim_has_architect"      id="h-architect">
              <input type="hidden" name="target_final"           id="h-target-final">

              <!-- ─────────────────────────────────────────────────────── -->
              <!-- VALOR DE ENTRADA                                        -->
              <!-- ─────────────────────────────────────────────────────── -->
              <div class="sec-hdr">
                <i class="fa-solid fa-dollar-sign"></i>
                Valores Base
              </div>
              <div class="sec-body">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="fw-bold mb-1" style="color: var(--brand); font-size: .88rem;">
                      <i class="fa-solid fa-box me-1"></i>Valor dos Produtos (R$)
                    </label>
                    <div class="input-group">
                      <span class="input-group-text fw-bold" style="background: var(--brand); color: #fff;">R$</span>
                      <input type="text" id="input-subtotal" name="sim_subtotal"
                             class="form-control value-input"
                             inputmode="decimal"
                             value="{% if sim_subtotal %}{{ sim_subtotal|floatformat:2 }}{% endif %}"
                             placeholder="0,00"
                             oninput="maskCurrency(this); scheduleSubmit()">
                    </div>
                  </div>
                  <div class="col-md-6">
                    <label class="fw-bold mb-1" style="color: var(--brand); font-size: .88rem;">
                      <i class="fa-solid fa-truck me-1"></i>Frete (R$)
                    </label>
                    <div class="input-group">
                      <span class="input-group-text fw-bold" style="background: var(--brand); color: #fff;">R$</span>
                      <input type="text" id="input-freight" name="sim_freight"
                             class="form-control value-input"
                             inputmode="decimal"
                             value="{% if sim_freight %}{{ sim_freight|floatformat:2 }}{% endif %}"
                             placeholder="0,00"
                             oninput="maskCurrency(this); scheduleSubmit()">
                    </div>
                  </div>
                </div>
              </div>

              <!-- ─────────────────────────────────────────────────────── -->
              <!-- DESCONTO                                                -->
              <!-- ─────────────────────────────────────────────────────── -->
              <div class="sec-hdr">
                <i class="fa-solid fa-tag"></i>
                Desconto
              </div>
              <div class="sec-body">
                <div class="d-flex justify-content-between mb-1 fw-bold" style="font-size: .88rem;">
                  <span style="color: var(--gray);">0%</span>
                  <span id="lbl-discount" style="color: var(--brand); font-size: 1.05rem; font-weight: 700;">
                    {% if discount_percent > 0 %}-{{ discount_percent }}% desconto{% else %}Sem desconto{% endif %}
                  </span>
                  <span style="color: var(--red);" id="lbl-max-discount">{{ max_discount_allowed|floatformat:0 }}%</span>
                </div>
                <div class="slider-wrap">
                  <input type="range" id="discount-slider"
                         min="0" max="{{ max_discount_allowed|floatformat:1 }}" step="0.5"
                         value="{{ discount_percent }}"
                         oninput="onDiscountChange(this.value); scheduleSubmit()">
                </div>
                {% if controls_blocked %}
                <div class="alert alert-danger py-2 px-3 mb-2" style="font-size:.82rem;border-radius:0;">
                  <i class="fa-solid fa-lock me-1"></i>
                  <strong>Limite atingido!</strong> A margem chegou ao máximo de -5%. Desconto limitado a {{ max_discount_allowed|floatformat:1 }}%.
                </div>
                {% endif %}
                <div class="row g-2">
                  <div class="col-md-6">
                    <div class="sim-card py-2 px-3 mb-0">
                      <div class="lbl">Desconto aplicado</div>
                      <div class="val red" id="live-discount-val">{{ discount_percent }}%</div>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="sim-card py-2 px-3 mb-0">
                      <div class="lbl">Valor do desconto</div>
                      <div class="val red" id="live-discount-amount">R$ {{ discount_value|floatformat:2 }}</div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- ─────────────────────────────────────────────────────── -->
              <!-- AJUSTE DE VALOR                                         -->
              <!-- ─────────────────────────────────────────────────────── -->
              <div class="sec-hdr">
                <button type="button"
                        class="commission-toggle"
                        data-bs-toggle="collapse"
                        data-bs-target="#increase-collapse"
                        aria-expanded="false"
                        aria-controls="increase-collapse">
                  <span><i class="fa-solid fa-sliders me-2"></i>Ajuste de Valor</span>
                  <i class="fa-solid fa-chevron-down toggle-arrow"></i>
                </button>
              </div>
              <div class="sec-body collapse" id="increase-collapse">
                <div id="increase-suggestion-zone">
                {% if commission_reduced %}
                <div class="{% if margin_exceeded %}margin-warning{% else %}margin-ok{% endif %}">
                  <i class="fa-solid fa-{% if margin_exceeded %}triangle-exclamation text-warning{% else %}shield-check text-success{% endif %} me-1"></i>
                  {% if margin_exceeded %}
                  <strong>Passou da margem!</strong> Comissão no mínimo ({{ seller_commission_percent }}%),
                  mas o custo total ({{ total_cost_pct }}%) ainda excede a margem ({{ effective_margin }}%).
                  {% if suggested_increase > 0 %}Sugestão: aplicar {% if price_increase_pct > 0 %}mais {% endif %}<strong>+{{ suggested_increase }}%</strong> de ajuste no valor.{% endif %}
                  {% else %}
                  <strong>Comissão proporcional:</strong> {{ seller_commission_percent }}% (faixa: 3% a 5%, baseada na margem disponível).
                  {% endif %}
                </div>
                {% elif margin_exceeded and suggested_increase > 0 %}
                <div class="margin-warning">
                  <i class="fa-solid fa-triangle-exclamation text-warning me-1"></i>
                  <strong>Passou da margem!</strong> Taxa ({{ store_fee_percent }}%) + Comissão ({{ seller_commission_percent }}%)
                  {% if sim_has_architect %}+ Arquiteto ({{ architect_percent }}%){% endif %}
                  {% if discount_percent > 0 %}+ Desconto ({{ discount_percent }}%){% endif %}
                  = <strong>{{ total_cost_pct }}%</strong> (margem: {{ effective_margin }}%).
                  Sugestão: aplicar {% if price_increase_pct > 0 %}mais {% endif %}<strong>+{{ suggested_increase }}%</strong> de ajuste no valor.
                </div>
                {% endif %}
                </div>

                <div class="d-flex justify-content-between mb-1 fw-bold" style="font-size: .88rem;">
                  <span style="color: var(--gray);">0%</span>
                  <span id="lbl-increase" style="color: var(--green); font-size: 1.05rem; font-weight: 700;">
                    {% if price_increase_pct > 0 %}+{{ price_increase_pct }}% no valor{% else %}Sem ajuste{% endif %}
                  </span>
                  <span style="color: var(--green);">30%</span>
                </div>
                <div class="slider-wrap">
                  <input type="range" id="increase-slider"
                         min="0" max="30" step="0.5"
                         value="{{ price_increase_pct }}"
                         style="background: linear-gradient(to right, var(--brand) 0%, var(--green) 100%);"
                         oninput="onIncreaseChange(this.value); scheduleSubmit()">
                </div>
                <div class="sim-card py-2 px-3 mb-0">
                  <div class="lbl">Ajuste aplicado</div>
                  <div class="val green" id="live-increase-val">{{ price_increase_pct }}%</div>
                </div>

                <!-- Controle de Margem (dentro do collapse) -->
                <hr class="my-3">
                <h6 class="fw-bold mb-3" style="color: var(--brand); font-size: .88rem;">
                  <i class="fa-solid fa-gauge-high me-2"></i>Controle de Margem
                </h6>
                <div id="margin-zone">
                {% if commission_reduced and not margin_exceeded %}
                <div class="margin-ok">
                  <i class="fa-solid fa-check-circle text-success me-1"></i>
                  <strong>Margem OK!</strong>
                  Comissão: {{ seller_commission_percent }}% (proporcional à margem disponível).
                  Custo total: <strong>{{ total_cost_pct }}%</strong> (margem: {{ effective_margin }}%)
                </div>
                {% elif margin_exceeded %}
                <div class="margin-warning">
                  <i class="fa-solid fa-triangle-exclamation text-warning me-2"></i>
                  <strong>Passou da margem!</strong><br>
                  Taxa: {{ store_fee_percent }}% + Comissão: {{ seller_commission_percent }}% (mín. 3%)
                  {% if sim_has_architect %}+ Arquiteto: {{ architect_percent }}%{% endif %}
                  {% if discount_percent > 0 %}+ Desconto: {{ discount_percent }}%{% endif %}
                  = <strong>{{ total_cost_pct }}%</strong><br>
                  Margem: <strong>{{ effective_margin }}%</strong>
                  {% if price_increase_pct > 0 %}({{ margin_base }}% + {{ price_increase_pct }}% ajuste){% endif %}
                  — Excesso: <strong>{{ margin_excess }}%</strong>
                  {% if suggested_increase > 0 %}
                  <br><i class="fa-solid fa-lightbulb text-warning me-1"></i>
                  Sugestão: aplique {% if price_increase_pct > 0 %}mais {% endif %}<strong>+{{ suggested_increase }}%</strong> de ajuste no valor para compensar.
                  {% endif %}
                </div>
                {% else %}
                <div class="margin-ok">
                  <i class="fa-solid fa-check-circle text-success me-1"></i>
                  <strong>Margem OK!</strong>
                  Custo total: <strong>{{ total_cost_pct }}%</strong> (margem: {{ effective_margin }}%)
                </div>
                {% endif %}

                {% if margin_limit_exceeded %}
                <div class="margin-danger">
                  <i class="fa-solid fa-ban text-danger me-1"></i>
                  <strong>Condições bloqueadas!</strong> O custo total (<strong>{{ total_cost_pct }}%</strong>) atingiu ou ultrapassou o limite de margem permitido (<strong>{{ margin_limit }}%</strong>).
                  Estas condições não podem ser aplicadas. Reduza o desconto, remova o arquiteto ou aumente o preço.
                </div>
                {% endif %}

                <div class="row g-2">
                  <div class="col-md-3">
                    <div class="sim-card py-2 px-3 mb-0">
                      <div class="lbl">Margem{% if price_increase_pct > 0 %} Efetiva{% endif %}</div>
                      <div class="val">{{ effective_margin }}%</div>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <div class="sim-card py-2 px-3 mb-0">
                      <div class="lbl">Taxa</div>
                      <div class="val {% if store_fee_percent > 10 %}red{% endif %}">{{ store_fee_percent }}%</div>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <div class="sim-card py-2 px-3 mb-0">
                      <div class="lbl">Comissão</div>
                      <div class="val">{{ seller_commission_percent }}%</div>
                    </div>
                  </div>
                  <div class="col-md-3">
                    <div class="sim-card py-2 px-3 mb-0">
                      <div class="lbl">Custo Total</div>
                      <div class="val {% if margin_exceeded %}red{% else %}green{% endif %}">{{ total_cost_pct }}%</div>
                    </div>
                  </div>
                </div>
                </div>
              </div>

              <!-- ─────────────────────────────────────────────────────── -->
              <!-- FORMA DE PAGAMENTO + PARCELAS                           -->
              <!-- ─────────────────────────────────────────────────────── -->
              <div class="sec-hdr">
                <i class="fa-solid fa-credit-card"></i>
                Forma de Pagamento / Parcelas
              </div>
              <div class="sec-body">
                <div class="row mb-3 align-items-end">
                  <div class="col-md-5">
                    <label class="fw-bold mb-1" style="color: var(--brand); font-size: .88rem;">
                      <i class="fa-solid fa-credit-card me-1"></i>Forma de Pagamento
                    </label>
                    <select id="sel-ptype" class="form-select" onchange="onPaymentTypeChange()">
                      <option value="">-- Selecione --</option>
                      {% for value, label in payment_type_choices %}
                        <option value="{{ value }}" {% if value == sim_payment_type %}selected{% endif %}>{{ label }}</option>
                      {% endfor %}
                    </select>
                  </div>

                  <div class="col-md-4" id="inst-dropdown-row">
                    <label class="fw-bold mb-1" style="color: var(--brand); font-size: .88rem;">
                      <i class="fa-solid fa-hashtag me-1"></i>Parcelas

                    </label>
                    <select id="inst-select" class="form-select" onchange="onInstChange(this.value); scheduleSubmit();"></select>
                  </div>

                  <div class="col-md-3">
                    <div class="sim-card mb-0 py-2 px-3" style="border-left: 3px solid var(--brand);">
                      <div class="lbl mb-0">Taxa do Pagamento</div>
                      <div class="val" style="font-size: 1.05rem;" id="fee-display">{{ payment_fee_percent }}%</div>
                    </div>
                  </div>
                </div>


              </div>

              <!-- ─────────────────────────────────────────────────────── -->
              <!-- ARQUITETO                                               -->
              <!-- ─────────────────────────────────────────────────────── -->
              <div class="sec-hdr"><i class="fa-solid fa-drafting-compass"></i>Arquiteto</div>
              <div class="sec-body">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="chk-architect"
                         value="1"
                         {% if sim_has_architect %}checked{% endif %}
                         onchange="scheduleSubmit()">
                  <label class="form-check-label fw-bold" for="chk-architect" style="color: var(--brand);">
                    Cliente possui Arquiteto
                    ({{ architect_percent }}% sobre valor à vista)
                  </label>
                </div>
                {% if sim_has_architect %}
                <div class="sim-card mt-2 py-2 px-3 mb-0">
                  <div class="lbl">Valor base para cálculo do arquiteto</div>
                  <div class="val">R$ {{ valor_avista|floatformat:2 }}</div>
                </div>
                {% endif %}
              </div>



              <!-- ─────────────────────────────────────────────────────── -->
              <!-- RESULTADOS                                              -->
              <!-- ─────────────────────────────────────────────────────── -->
              <div id="sim-results">
              <span id="sim-data"
                    data-max-discount="{{ max_discount_allowed|floatformat:1 }}"

                    data-controls-blocked="{{ controls_blocked|yesno:'1,0' }}"
                    data-discount-clamped="{{ discount_percent|floatformat:1 }}"
                    data-price-increase="{{ price_increase_pct|floatformat:1 }}"
                    data-target-mode="{{ target_mode|yesno:'1,0' }}"

                    style="display:none;"></span>
              <div class="sec-hdr"><i class="fa-solid fa-chart-bar"></i>Resumo dos Valores</div>
              <div class="sec-body">
                {% if subtotal > 0 %}
                <div class="row g-2">
                  {% if freight_value > 0 %}
                  <div class="col-md-4">
                    <div class="sim-card">
                      <div class="lbl">Frete</div>
                      <div class="val">R$ {{ freight_value|floatformat:2 }}</div>
                    </div>
                  </div>
                  {% endif %}
                  <div class="col-md-4">
                    <div class="sim-card">
                      <div class="lbl">Total antes do desconto</div>
                      <div class="val">R$ {{ total_before_discount|floatformat:2 }}</div>
                    </div>
                  </div>
                  {% if discount_percent > 0 %}
                  <div class="col-md-4">
                    <div class="sim-card">
                      <div class="lbl">Desconto ({{ discount_percent }}%)</div>
                      <div class="val red">– R$ {{ discount_value|floatformat:2 }}</div>
                    </div>
                  </div>
                  {% endif %}
                  {% if client_surcharge_value > 0 %}
                  <div class="col-md-4">
                    <div class="sim-card">
                      <div class="lbl">Juros do parcelamento ({{ client_surcharge_percent }}%)</div>
                      <div class="val red">+ R$ {{ client_surcharge_value|floatformat:2 }}</div>
                      <div style="font-size:.72rem;color:var(--gray);">Cobrado do cliente</div>
                    </div>
                  </div>
                  {% endif %}
                </div>

                <!-- Final total -->
                <div class="hi-card brand mt-1">
                  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                      <div class="lbl">Total Final para o Cliente</div>
                      <div class="val">R$ {{ final_total|floatformat:2 }}</div>
                    </div>
                    <div style="text-align: right;">
                      <div class="lbl">Pagamento</div>
                      <div style="font-size: 1rem;">{{ sim_payment_description }}</div>
                      {% if sim_installments > 1 %}
                      <div class="lbl mt-2">Valor da Parcela</div>
                      <div style="font-size: 1.1rem; font-weight: 700;">{{ sim_installments }}x de R$ {{ installment_value|floatformat:2 }}</div>
                      {% endif %}
                    </div>
                  </div>
                </div>

                <!-- TARGET FINAL INPUT -->
                <div class="mt-2" style="background: #f0f4ff; border: 1px dashed var(--brand); border-radius: 4px; padding: .85rem 1rem;">
                  <label for="target-final-input" style="font-size: .82rem; font-weight: 700; color: var(--brand); display: block; margin-bottom: .4rem;">
                    <i class="fa-solid fa-bullseye me-1"></i>Valor Final Desejado
                  </label>
                  <div class="d-flex gap-2 align-items-center">
                    <span style="font-weight:700; color: var(--brand);">R$</span>
                    <input type="text" id="target-final-input" class="form-control form-control-sm"
                           placeholder="Digitar valor desejado..."
                           value="{% if target_mode %}{{ target_final_input|floatformat:2 }}{% endif %}"
                           style="max-width: 200px; font-weight: 700; font-size: 1rem;"
                           inputmode="decimal">
                    <button type="button" class="btn btn-sm"
                            style="background: var(--brand); color: #fff; font-weight: 600; white-space: nowrap;"
                            onclick="applyTargetFinal()">
                      <i class="fa-solid fa-calculator me-1"></i>Calcular
                    </button>
                    {% if target_mode %}
                    <button type="button" class="btn btn-sm btn-outline-secondary"
                            onclick="clearTargetFinal()" title="Limpar">
                      <i class="fa-solid fa-xmark"></i>
                    </button>
                    {% endif %}
                  </div>
                  {% if target_mode %}
                  <div style="font-size: .78rem; color: var(--brand); margin-top: .4rem;">
                    <i class="fa-solid fa-check-circle me-1"></i>
                    Condições ajustadas automaticamente para atingir R$ {{ target_final_input|floatformat:2 }}
                  </div>
                  {% endif %}
                </div>

                <!-- Commission cards -->
                <div class="row g-2 mt-1">
                  {% if sim_has_architect %}
                  <div class="col-md-6">
                    <div class="hi-card gray">
                      <div class="lbl">Comissão do Arquiteto ({{ architect_percent }}%)</div>
                      <div class="val">R$ {{ architect_commission_value|floatformat:2 }}</div>
                      <div style="font-size: .8rem; opacity: .85; margin-top: .4rem;">
                        {{ architect_percent }}% sobre R$ {{ valor_avista|floatformat:2 }}
                      </div>
                    </div>
                  </div>
                  {% endif %}
                  <div class="col-md-{% if sim_has_architect %}6{% else %}12{% endif %}">
                    <div class="hi-card {% if margin_exceeded %}orange{% elif seller_commission_percent >= 4 %}green{% else %}brand{% endif %}">
                      <button type="button"
                              class="commission-toggle"
                              data-bs-toggle="collapse"
                              data-bs-target="#seller-commission-collapse"
                              aria-expanded="false"
                              aria-controls="seller-commission-collapse">
                        <span class="lbl mb-0">Comissão do Vendedor</span>
                        <i class="fa-solid fa-chevron-down toggle-arrow"></i>
                      </button>
                      <div id="seller-commission-collapse" class="collapse mt-2">
                        <div class="val">R$ {{ seller_commission_value|floatformat:2 }}</div>
                        <div style="font-size: .8rem; opacity: .85; margin-top: .4rem;">
                          {{ seller_commission_percent }}% sobre R$ {{ seller_commission_base|floatformat:2 }}
                          {% if sim_has_architect %} (após comissão arquiteto){% endif %}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                {% else %}
                <div class="text-center py-4" style="color: var(--gray);">
                  <i class="fa-solid fa-info-circle fa-2x mb-2"></i>
                  <p class="mb-0">Insira o valor dos produtos acima para ver os resultados da simulação.</p>
                </div>
                {% endif %}
              </div>
              </div><!-- /sim-results -->

              <!-- ─────────────────────────────────────────────────────── -->
              <!-- BOTÕES                                                  -->
              <!-- ─────────────────────────────────────────────────────── -->
              <div class="bg-white p-4 shadow-sm mb-4">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                  <div class="d-flex gap-2 flex-wrap">
                    <button type="button" class="btn-brand" onclick="resetSimulation()">
                      <i class="fa-solid fa-rotate-left me-1"></i>Nova Simulação
                    </button>
                  </div>
                  <a href="{% url 'core:index' %}" class="btn-outline" style="text-decoration: none;">
                    <i class="fa-solid fa-home me-1"></i>Início
                  </a>
                </div>
              </div>

            </form>

          </div>
        </div>
      </div>
    </section>

    <section class="pt-4 pb-3" style="background: var(--brand); color: #fff;">
      <div class="container text-center">
        <p class="mb-0">&copy; 2026 Roselar. Todos os direitos reservados.</p>
      </div>
    </section>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js"></script>
  <script src="{% static 'assets/js/theme.js' %}"></script>

  <script>
  if ('scrollRestoration' in history) history.scrollRestoration = 'manual';

  var tariffsByType      = JSON.parse('{{ tariffs_by_type_json|escapejs }}');
  var initDiscount       = parseFloat('{{ discount_percent }}');
  var initPriceInc       = parseFloat('{{ price_increase_pct }}');
  var initInstall        = parseInt('{{ sim_installments }}');
  var initPType          = '{{ sim_payment_type }}';
  var MARGIN_BASE        = parseFloat('{{ margin_base }}');

  function onDiscountChange(val) {
    val = parseFloat(val);
    document.getElementById('h-discount').value = val.toFixed(1);
    document.getElementById('live-discount-val').textContent = val.toFixed(1) + '%';
    if (val > 0) {
      document.getElementById('lbl-discount').textContent = '-' + val.toFixed(1) + '% desconto';
      document.getElementById('lbl-discount').style.color = 'var(--red)';
    } else {
      document.getElementById('lbl-discount').textContent = 'Sem desconto';
      document.getElementById('lbl-discount').style.color = 'var(--brand)';
    }
  }

  function onIncreaseChange(val) {
    val = parseFloat(val);
    document.getElementById('h-price-inc').value = val.toFixed(1);
    document.getElementById('live-increase-val').textContent = val.toFixed(1) + '%';
    if (val > 0) {
      document.getElementById('lbl-increase').textContent = '+' + val.toFixed(1) + '% no valor';
      document.getElementById('lbl-increase').style.color = 'var(--green)';
    } else {
      document.getElementById('lbl-increase').textContent = 'Sem ajuste';
      document.getElementById('lbl-increase').style.color = 'var(--brand)';
    }
  }

  function onInstChange(val) {
    val = parseInt(val);
    document.getElementById('h-installments').value = val;
    updateFeeDisplay(val);
  }

  function onPaymentTypeChange() {
    var pt = document.getElementById('sel-ptype').value;
    document.getElementById('h-ptype').value = pt;
    var hasInstallments = (pt === 'CREDIT_CARD' || pt === 'BOLETO');
    var instRow = document.getElementById('inst-dropdown-row');
    instRow.style.display = hasInstallments ? '' : 'none';
    if (!hasInstallments) {
      document.getElementById('inst-select').value = 1;
      document.getElementById('h-installments').value = 1;
    }
    rebuildInstOptions();
    updateFeeDisplay(parseInt(document.getElementById('inst-select').value) || 1);
    scheduleSubmit();
  }

  function rebuildInstOptions() {
    var pt = document.getElementById('sel-ptype').value;
    var options = tariffsByType[pt] || [];
    var instSel = document.getElementById('inst-select');
    var curVal  = parseInt(instSel.value) || 1;
    instSel.innerHTML = '';
    options.forEach(function(o) {
      var opt = document.createElement('option');
      opt.value = o.installments;
      opt.textContent = o.label;
      if (o.installments === curVal) opt.selected = true;
      instSel.appendChild(opt);
    });
    if (!instSel.value) instSel.value = 1;
  }

  function updateFeeDisplay(installments) {
    var ptype   = document.getElementById('sel-ptype').value;
    var options = tariffsByType[ptype] || [];
    var fee     = 0;
    options.forEach(function(o) {
      if (o.installments === installments) fee = o.fee;
    });
    document.getElementById('fee-display').textContent = fee.toFixed(2) + '%';
  }

  var submitTimer = null;
  var pendingTargetFinal = '';

  function scheduleSubmit() {
    pendingTargetFinal = '';
    clearTimeout(submitTimer);
    submitTimer = setTimeout(doSubmit, 500);
  }

  function parseBRL(str) {
    if (!str) return 0;
    // Remove everything except digits and comma/dot
    str = str.replace(/[^\d.,]/g, '');
    // Brazilian format: 1.234,56 → replace dots (thousands) then comma (decimal)
    str = str.replace(/\./g, '').replace(',', '.');
    return parseFloat(str) || 0;
  }

  function maskCurrency(el) {
    // Accumulator pattern: strip non-digits, divide by 100, format as BRL
    var raw = el.value.replace(/\D/g, '');
    if (!raw) { el.value = ''; return; }
    // Remove leading zeros but keep at least one digit
    raw = raw.replace(/^0+/, '') || '0';
    // Pad to at least 3 chars for cents
    while (raw.length < 3) raw = '0' + raw;
    var intPart = raw.slice(0, -2);
    var decPart = raw.slice(-2);
    // Thousands separator
    intPart = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    el.value = intPart + ',' + decPart;
    // Accumulator: cursor always at end
    try { el.setSelectionRange(el.value.length, el.value.length); } catch(e) {}
  }

  function formatInitialValue(el) {
    if (!el.value) return;
    // Django outputs US format "1234.56" — parse with parseFloat, NOT parseBRL
    var v = parseFloat(el.value);
    if (v > 0) {
      el.value = v.toLocaleString('pt-BR', {minimumFractionDigits: 2, maximumFractionDigits: 2});
    } else {
      el.value = '';
    }
  }

  function doSubmit() {
    var discount  = parseFloat(document.getElementById('discount-slider').value) || 0;
    var priceInc  = parseFloat(document.getElementById('increase-slider').value) || 0;
    var subtotal  = parseBRL(document.getElementById('input-subtotal').value);
    var freight   = parseBRL(document.getElementById('input-freight').value);

    document.getElementById('h-discount').value     = discount.toFixed(1);
    document.getElementById('h-price-inc').value    = priceInc.toFixed(1);
    document.getElementById('h-installments').value = document.getElementById('inst-select').value;
    document.getElementById('h-ptype').value        = document.getElementById('sel-ptype').value;
    document.getElementById('h-architect').value    = document.getElementById('chk-architect').checked ? '1' : '0';

    var fd = new FormData();
    fd.append('csrfmiddlewaretoken', document.querySelector('[name=csrfmiddlewaretoken]').value);
    fd.append('_ajax', '1');
    fd.append('sim_subtotal',           subtotal.toFixed(2));
    fd.append('sim_freight',            freight.toFixed(2));
    fd.append('discount_percent',       discount.toFixed(1));
    fd.append('price_increase_percent', priceInc.toFixed(1));
    fd.append('sim_installments',       document.getElementById('inst-select').value);
    fd.append('sim_payment_type',       document.getElementById('sel-ptype').value);
    fd.append('sim_has_architect',      document.getElementById('chk-architect').checked ? '1' : '0');
    if (pendingTargetFinal) {
      fd.append('target_final', pendingTargetFinal);
    }

    fetch(window.location.href, {method: 'POST', body: fd})
      .then(function(r) { return r.text(); })
      .then(applyZones)
      .catch(function(e) { console.error('Sim AJAX error:', e); });
  }

  function applyZones(html) {
    var doc = new DOMParser().parseFromString(html, 'text/html');
    ['sim-results', 'margin-zone', 'increase-suggestion-zone'].forEach(function(id) {
      var newEl = doc.getElementById(id);
      var curEl = document.getElementById(id);
      if (newEl && curEl) curEl.outerHTML = newEl.outerHTML;
    });
    // Update discount R$ value (outside replaced zones)
    var newDA = doc.getElementById('live-discount-amount');
    var curDA = document.getElementById('live-discount-amount');
    if (newDA && curDA) curDA.textContent = newDA.textContent;

    // Sync discount slider max from server response
    var simData = document.getElementById('sim-data');
    if (simData) {
      var maxDisc = parseFloat(simData.dataset.maxDiscount) || 30;
      var clampedDisc = parseFloat(simData.dataset.discountClamped) || 0;
      var slider = document.getElementById('discount-slider');
      slider.max = maxDisc;
      if (parseFloat(slider.value) > maxDisc) {
        slider.value = clampedDisc;
        onDiscountChange(clampedDisc);
      }
      var lblMax = document.getElementById('lbl-max-discount');
      if (lblMax) lblMax.textContent = Math.round(maxDisc) + '%';

      // Target mode: sync sliders to server-calculated values
      if (simData.dataset.targetMode === '1') {
        var newDisc = parseFloat(simData.dataset.discountClamped) || 0;
        var newPI   = parseFloat(simData.dataset.priceIncrease) || 0;
        slider.max   = maxDisc;
        slider.value = newDisc;
        onDiscountChange(newDisc);
        var incSlider = document.getElementById('increase-slider');
        incSlider.value = newPI;
        onIncreaseChange(newPI);
      }
    }
  }

  // ── Target final (reverse calculation) ─────────────────────────────────────
  function applyTargetFinal() {
    var input = document.getElementById('target-final-input');
    var val = input.value.replace(/\./g, '').replace(',', '.').trim();
    if (!val || isNaN(parseFloat(val)) || parseFloat(val) <= 0) {
      input.focus();
      return;
    }
    pendingTargetFinal = val;
    doSubmit();
  }

  function clearTargetFinal() {
    document.getElementById('target-final-input').value = '';
    pendingTargetFinal = '';
    scheduleSubmit();
  }

  function resetSimulation() {
    document.getElementById('input-subtotal').value = '';
    document.getElementById('input-freight').value = '';
    document.getElementById('input-subtotal').placeholder = '0,00';
    document.getElementById('input-freight').placeholder = '0,00';
    document.getElementById('discount-slider').value = 0;
    document.getElementById('increase-slider').value = 0;
    document.getElementById('sel-ptype').value = '';
    document.getElementById('chk-architect').checked = false;
    onDiscountChange(0);
    onIncreaseChange(0);
    onPaymentTypeChange();
    scheduleSubmit();
  }

  (function init() {
    document.getElementById('h-discount').value     = initDiscount.toFixed(1);
    document.getElementById('h-price-inc').value     = initPriceInc.toFixed(1);
    document.getElementById('h-installments').value  = initInstall;
    document.getElementById('h-ptype').value         = initPType;
    document.getElementById('h-architect').value     = '{{ sim_has_architect|yesno:"1,0" }}';

    document.getElementById('discount-slider').value = initDiscount;
    document.getElementById('increase-slider').value = initPriceInc;

    rebuildInstOptions();
    var instSel = document.getElementById('inst-select');
    instSel.value = initInstall;

    var hasInstallments = (initPType === 'CREDIT_CARD' || initPType === 'BOLETO');
    document.getElementById('inst-dropdown-row').style.display = hasInstallments ? '' : 'none';

    updateFeeDisplay(initInstall);

    // Format initial values with mask
    formatInitialValue(document.getElementById('input-subtotal'));
    formatInitialValue(document.getElementById('input-freight'));

    // Enter key on target input triggers calculate
    var targetInput = document.getElementById('target-final-input');
    if (targetInput) {
      targetInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') { e.preventDefault(); applyTargetFinal(); }
      });
    }
  })();
  </script>
</body>
</html>
