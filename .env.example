# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost

# Production/Railway database URL (in Railway set only DATABASE_URL)
# Example:
# DATABASE_URL=postgresql://user:password@postgres.railway.internal:5432/railway
DATABASE_URL=

# Optional local-only Postgres URL when running outside Railway.
# If empty, local dev falls back to SQLite at db.sqlite3.
# Example:
# LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/projeto_roselar
LOCAL_DATABASE_URL=
